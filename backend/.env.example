# Required: Get free key at https://finnhub.io/register
FINNHUB_API_KEY=your_finnhub_key_here

# Optional: Get free key at https://newsapi.org/register
# Free tier: 100 req/day, 30-day article window
# If not set, NewsAPI source is skipped gracefully
NEWSAPI_API_KEY=your_newsapi_key_here

# Server port (default: 3001)
PORT=3001

# Set to "production" when deploying
NODE_ENV=development

# Required in production: your Vercel frontend URL
# e.g. https://indian-stock-news.vercel.app
FRONTEND_URL=
